def build_efficientnet_backbone(input_shape=IMG_SHAPE, emb_dim=EMBEDDING_DIM):
    """
    Transfer Learning backbone using EfficientNetB0.

    EXPERT FIXES applied (explains why TL was worse than CNN before):

    FIX 1 — PREPROCESSING (critical):
    Old code: Rescaling(255.0) → base (which also had internal preprocessing)
    → double-scaling: model received [0, 65025] instead of [-1, 1]
    → pretrained ImageNet weights completely useless under wrong input range.
    New code: include_preprocessing=False + EfficientNetPreprocessLayer maps [0,1]→[-1,1].

    FIX 2 — HEAD SIZE (Phase 1 convergence):
    Old head: 512→256→128 with Dropout(0.40) + Dropout(0.30) = 250K+ params.
    With only 15 Phase 1 epochs at LR=3e-4, this oversized head never converged,
    so Phase 2 fine-tuning started from a bad initialization.
    New head: 256→128 (2 Dense layers, Dropout 0.35 + 0.20) = 40K params — converges
    in 15–20 epochs reliably, giving Phase 2 a clean starting point.

    FIX 3 — PHASE 2 UNFREEZING (coverage):
    Old: unfreeze last 30 layers (≈ top 13% of EfficientNetB0's 237 layers).
    30 layers barely touched the MBConv blocks that learn face-relevant features.
    New: unfreeze last 50 layers (≈ top 21%) to include top MBConv stages
    while keeping the efficient low-level feature extractors frozen.
    """
    base = EfficientNetB0(
        input_shape=input_shape,
        include_top=False,
        weights="imagenet",
        pooling="avg",
        # include_preprocessing=False  # FIX 1: This argument is not supported in this TensorFlow version.
    )
    base.trainable = False   # Phase 1: freeze entire base

    inputs = Input(shape=input_shape, name="efficientnet_input")

    # FIX 1: Correct preprocessing — EfficientNetPreprocessLayer maps [0,1]→[-1,1]
    x   = EfficientNetPreprocessLayer(name="efficientnet_preprocess")(inputs)
    x   = base(x, training=False)

    # FIX 2: Simplified head — 256→128 converges in Phase 1 warm-up epochs
    x   = Dense(256, activation="relu", name="emb_dense1")(x)
    x   = Dropout(0.35, name="emb_drop1")(x)
    x   = Dense(emb_dim, activation=None, name="emb_proj")(x)
    out = L2NormalizeLayer(name="l2_norm")(x)

    model = Model(inputs, out, name="EfficientNetB0_Backbone")
    return model, base

